{
    "name": "tenancy-tools/laravel-tenant-backup",
    "description": "Tenant-aware database backup module for Laravel applications using Spatie Backup.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "spatie/laravel-backup": "*",
        "symfony/process": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "TenancyTools\\TenantBackup\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TenancyTools\\TenantBackup\\TenantBackupServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
